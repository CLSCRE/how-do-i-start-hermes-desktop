    "trigger": [
      {
        "triggerId": "2147479550",
        "name": "All Pages",
        "type": "PAGEVIEW",
        "filter": []
      },
      {
        "triggerId": "2147479551",
        "name": "Click - Telephone",
        "type": "CLICK",
        "filter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
