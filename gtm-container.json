              { "key": "arg1", "value": "[data-cta=apply]" }
            ]
          }
        ]
      }
    ],
    "variable": [
      { "name": "Click URL", "type": "CLICK_URL" },
      { "name": "Click Element", "type": "CLICK_ELEMENT" },
      { "name": "Form ID", "type": "FORM_ID" },
